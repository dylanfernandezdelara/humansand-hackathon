# Copy to .env.local and fill in OPENROUTER_API_KEY.
# This fork uses Dylan's Convex deployment (team: dylan-fernandez-de-lara).

CONVEX_DEPLOYMENT=dev:usable-badger-650
NEXT_PUBLIC_CONVEX_URL=https://usable-badger-650.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://usable-badger-650.convex.site

# OpenRouter — free tier only (app uses model id `openrouter/free`).
# Also set on Convex: npx convex env set OPENROUTER_API_KEY your-key-here
OPENROUTER_API_KEY=
